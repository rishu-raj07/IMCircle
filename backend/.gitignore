# Dependencies
node_modules

# Environment / secrets — never commit real API keys, tokens, DB URIs, or
# JWT secrets. Only the checked-in .example templates (placeholder values
# only) should ever be tracked.
.env
.env.*
!.env.example
!.env.production.example

# Firebase service account key (push notifications — see
# src/config/firebaseAdmin.js). This grants admin access to the Firebase
# project; never commit it. Prefer storing it outside this repo entirely
# on the server and pointing FIREBASE_SERVICE_ACCOUNT_PATH at it, but this
# ignore rule is a backstop in case a copy ever ends up in this folder.
firebase-service-account*.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.swp

# Build/coverage output
dist
coverage
